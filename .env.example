# Notion API Configuration
# Get your Notion API key from: https://www.notion.so/my-integrations
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Algolia Search Configuration
# Get credentials from: https://www.algolia.com/doc/tools/crawler/apis/configuration/
ALGOLIA_APP_ID=your_algolia_app_id_here
ALGOLIA_ADMIN_API_KEY=your_algolia_admin_key_here
ALGOLIA_INDEX_NAME=ariadocusauruswed_netlify_app_pages

# Netlify Configuration
SITE_URL=https://ariadocusauruswed.netlify.app
SYNC_SECRET=your_random_secret_for_sync_endpoint

# Notion Books Cache TTL (in seconds)
NOTION_CACHE_TTL_SECONDS=300

# GitHub or Other CI/CD (if needed)
# CI=true
